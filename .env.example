# LLM provider
ANTHROPIC_API_KEY=sk-ant-...

# Token0 proxy (optional — set if running token0 locally)
TOKEN0_BASE_URL=http://localhost:8000

# PagerDuty
PAGERDUTY_WEBHOOK_SECRET=

# App
DATABASE_URL=sqlite+aiosqlite:///./runbookai.db
SUGGEST_MODE=true   # set to false to enable autonomous execution

# Email escalation (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ESCALATION_EMAIL=

# Slack escalation (optional)
SLACK_WEBHOOK_URL=  # optional — paste your Slack incoming webhook URL
