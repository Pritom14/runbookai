# LLM provider — works with Ollama, OpenAI, Anthropic, Groq, or any OpenAI-compatible endpoint
# Ollama (local, no API key)
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5:7b
LLM_API_KEY=ollama

# OpenAI
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o
# LLM_API_KEY=sk-...

# Anthropic
# LLM_BASE_URL=https://api.anthropic.com/v1
# LLM_MODEL=claude-sonnet-4-6
# LLM_API_KEY=sk-ant-...

# Groq (fast + cheap, great tool calling)
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_API_KEY=gsk_...

# App
DATABASE_URL=sqlite+aiosqlite:///./runbookai.db
SUGGEST_MODE=true   # set to false for autonomous execution

# SSH — global defaults (override per-host via POST /api/hosts)
SSH_DEFAULT_USERNAME=ubuntu
SSH_PRIVATE_KEY_PATH=~/.ssh/id_rsa

# PagerDuty (optional)
PAGERDUTY_WEBHOOK_SECRET=

# Slack escalation (optional)
SLACK_WEBHOOK_URL=

# Email escalation (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ESCALATION_EMAIL=

# Token0 proxy (optional — vision token optimization)
TOKEN0_BASE_URL=http://localhost:8000
